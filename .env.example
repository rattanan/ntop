DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/ntop_test"
AUTH_SECRET="replace-with-a-long-random-secret-at-least-32-characters"
SEED_ADMIN_EMAIL="admin@ntop.local"
SEED_ADMIN_PASSWORD="change-this-before-seeding"
# Base64 encoding of a random 32-byte key. Keep only in the deployment secret store.
AI_CONFIG_MASTER_KEY="replace-with-base64-encoded-32-byte-key"
# Durable AI job policy (deployment configuration, not business data)
AI_JOB_MAX_ATTEMPTS="3"
AI_JOB_MAX_CONCURRENT_PER_REQUESTER="2"
AI_JOB_MAX_QUEUED_PER_REQUESTER="5"
AI_JOB_LEASE_MS="60000"
AI_JOB_RETRY_DELAY_MS="1000,5000,30000"
