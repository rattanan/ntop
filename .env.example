DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/ntop_test"
AUTH_SECRET="replace-with-a-long-random-secret-at-least-32-characters"
SEED_ADMIN_EMAIL="admin@ntop.local"
SEED_ADMIN_PASSWORD="change-this-before-seeding"
# Explicit opt-in for synthetic Phase 1 demo users, campaigns, and Leads.
SEED_DEMO_DATA="0"
SEED_DEMO_PASSWORD="replace-with-demo-only-password-12-chars-minimum"
# Base64 encoding of a random 32-byte key. Keep only in the deployment secret store.
AI_CONFIG_MASTER_KEY="replace-with-base64-encoded-32-byte-key"
# Durable AI job policy (deployment configuration, not business data)
AI_JOB_MAX_ATTEMPTS="3"
AI_JOB_MAX_CONCURRENT_PER_REQUESTER="2"
AI_JOB_MAX_QUEUED_PER_REQUESTER="5"
AI_JOB_LEASE_MS="60000"
AI_JOB_RETRY_DELAY_MS="1000,5000,30000"
# Optional Deal Risk explanation. Deterministic signals remain available when false.
AI_DEAL_RISK_EXPLANATION_ENABLED="false"
AI_DEAL_RISK_CIRCUIT_FAILURE_THRESHOLD="3"
AI_DEAL_RISK_CIRCUIT_COOLDOWN_MS="60000"
# Optional Proposal drafting. Manual Proposal editing remains available when false.
AI_PROPOSAL_GENERATION_ENABLED="false"
# Phase 1 Site Survey is manual. The NTSP variables below document the future
# adapter contract only; the application does not use credentials or call NTSP.
NTSP_SITE_SURVEY_INTEGRATION_ENABLED="false"
SITE_SURVEY_INTEGRATION_MODE="MANUAL"
NTSP_SITE_SURVEY_API_BASE_URL=""
NTSP_SITE_SURVEY_CLIENT_ID=""
NTSP_SITE_SURVEY_CLIENT_SECRET=""
NTSP_SITE_SURVEY_AUTH_URL=""
NTSP_SITE_SURVEY_WEBHOOK_SECRET=""
NTSP_SITE_SURVEY_TIMEOUT_MS="30000"
