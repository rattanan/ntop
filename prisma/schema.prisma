generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SALES
  VIEWER
}

enum CustomerType {
  B2G
  B2B
}

enum CustomerStatus {
  PROSPECT
  ACTIVE
  INACTIVE
}

enum OpportunityStage {
  QUALIFY
  DISCOVER
  SOLUTION
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum SalesApproach {
  DIRECT
  PARTNER
  DISPLACE
}

enum LeadSource {
  IMPORT
  WEBSITE
  EVENT
  PARTNER
  REFERRAL
  EXISTING_CUSTOMER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  NURTURING
  CONVERTED
  DISQUALIFIED
}

enum ActivityType {
  CALL
  MEETING
  FOLLOW_UP
  TASK
}

enum QuoteStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SENT
  ACCEPTED
  EXPIRED
}

enum CoverageStatus {
  DRAFT
  REQUESTED
  CONFIRMED
  UNAVAILABLE
  RETURNED
}

enum InternalOrderStatus {
  DRAFT
  READY_FOR_HANDOFF
  SENT
  ACKNOWLEDGED
  RETURNED
  COMPLETED
}

enum AiJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum AiOutputStatus {
  DRAFT
  CONFIRMED
  REJECTED
  ABANDONED
}

enum AiSafetyResult {
  PASSED
  REJECTED
  REVIEW_REQUIRED
}

enum AiConfidenceBand {
  LOW
  MEDIUM
  HIGH
  UNKNOWN
}

enum AiFeedbackRating {
  HELPFUL
  INCORRECT
  UNSAFE
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  name           String
  passwordHash   String
  role           Role          @default(SALES)
  ownedCustomers Customer[]    @relation("CustomerOwner")
  ownedDeals     Opportunity[] @relation("OpportunityOwner")
  ownedLeads     Lead[]        @relation("LeadOwner")
  activities     Activity[]    @relation("ActivityOwner")
  requestedAiJobs AiJob[]      @relation("AiJobRequester")
  confirmedAiOutputs AiOutput[] @relation("AiOutputConfirmer")
  aiFeedback     AiFeedback[]   @relation("AiFeedbackActor")
  createdRiskRuleVersions DealRiskRuleVersion[] @relation("DealRiskRuleVersionCreator")
  confirmedMeetingDrafts MeetingDraftConfirmation[] @relation("MeetingDraftConfirmer")
  enterpriseRoleAssignments UserRoleAssignment[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Customer {
  id              String         @id @default(cuid())
  name            String
  taxId           String         @unique
  type            CustomerType
  segment         String
  province        String
  address         String?        @db.Text
  status          CustomerStatus @default(PROSPECT)
  ownerId         String
  owner           User           @relation("CustomerOwner", fields: [ownerId], references: [id])
  organizationUnitId String?
  organizationUnit OrganizationUnit? @relation(fields: [organizationUnitId], references: [id], onDelete: SetNull)
  contacts        Contact[]
  opportunities   Opportunity[]
  leads           Lead[]
  activities      Activity[]
  quotes          Quote[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([organizationUnitId, updatedAt])
  @@index([ownerId, updatedAt])
}

model OrganizationUnit {
  id        String   @id @default(cuid())
  code      String   @unique @db.VarChar(100)
  name      String   @db.VarChar(255)
  parentId  String?
  parent    OrganizationUnit?  @relation("OrganizationHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  OrganizationUnit[] @relation("OrganizationHierarchy")
  active    Boolean  @default(true)
  roleAssignments UserRoleAssignment[]
  customers Customer[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId, active])
}

model UserRoleAssignment {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  roleCode           String   @db.VarChar(100)
  scopeCode          String   @db.VarChar(32)
  organizationUnitId String?
  organizationUnit   OrganizationUnit? @relation(fields: [organizationUnitId], references: [id], onDelete: Restrict)
  effectiveFrom      DateTime
  effectiveTo        DateTime?
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([userId, roleCode, scopeCode, organizationUnitId, effectiveFrom])
  @@index([userId, active, effectiveFrom, effectiveTo])
  @@index([organizationUnitId, roleCode, active])
}

model Lead {
  id                  String     @id @default(cuid())
  company             String
  contactName         String
  contactEmail        String?
  contactPhone        String?
  source              LeadSource
  status              LeadStatus @default(NEW)
  score               Int        @default(0)
  recommendedProducts String?    @db.Text
  notes               String?    @db.Text
  ownerId             String
  owner               User       @relation("LeadOwner", fields: [ownerId], references: [id])
  customerId          String?
  customer            Customer?  @relation(fields: [customerId], references: [id])
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
}

model Activity {
  id            String       @id @default(cuid())
  subject       String
  type          ActivityType
  dueAt         DateTime?
  notes         String?      @db.Text
  aiSummary     String?      @db.Text
  actionItems   String?      @db.Text
  ownerId       String
  owner         User         @relation("ActivityOwner", fields: [ownerId], references: [id])
  customerId    String?
  customer      Customer?    @relation(fields: [customerId], references: [id])
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  meetingDraftConfirmation MeetingDraftConfirmation? @relation("MeetingConfirmationActivity")
  meetingDraftNextActionConfirmation MeetingDraftConfirmation? @relation("MeetingConfirmationNextAction")
}

model Contact {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name        String
  title       String?
  phone       String?
  email       String?
  relationship String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Opportunity {
  id              String           @id @default(cuid())
  name            String
  customerId      String
  customer        Customer         @relation(fields: [customerId], references: [id])
  flow            String
  stage           OpportunityStage @default(QUALIFY)
  estimatedValue  Decimal          @db.Decimal(15, 2)
  probability     Int
  expectedCloseAt DateTime?
  ownerId         String
  owner           User             @relation("OpportunityOwner", fields: [ownerId], references: [id])
  nextAction      String?
  requirements    String?          @db.Text
  vendorAssessment VendorAssessment?
  activities      Activity[]
  quotes          Quote[]
  coverageChecks  CoverageCheck[]
  solutionDesign  SolutionDesign?
  riskSignals     DealRiskSignal[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  category    String
  description String?  @db.Text
  listPrice   Decimal  @db.Decimal(15, 2)
  active      Boolean  @default(true)
  quoteItems  QuoteItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Quote {
  id            String      @id @default(cuid())
  quoteNo       String      @unique
  customerId    String
  customer      Customer    @relation(fields: [customerId], references: [id])
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  status        QuoteStatus @default(DRAFT)
  discountPct   Int         @default(0)
  subtotal      Decimal     @db.Decimal(15, 2)
  discountValue Decimal     @db.Decimal(15, 2) @default(0)
  total         Decimal     @db.Decimal(15, 2)
  validUntil    DateTime?
  notes         String?     @db.Text
  items         QuoteItem[]
  approvals     Approval[]
  internalOrder InternalOrder?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model CoverageCheck {
  id                  String         @id @default(cuid())
  opportunityId       String
  opportunity         Opportunity    @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  siteAddress         String         @db.Text
  circuitCount        Int            @default(1)
  status              CoverageStatus @default(DRAFT)
  fiberAvailable      Boolean?
  olt                 String?
  distanceKm          Decimal?       @db.Decimal(10,2)
  capacityMbps        Int?
  availablePorts      Int?
  expectedInstallDate DateTime?
  confirmedCost       Decimal?       @db.Decimal(15,2)
  responderNotes      String?        @db.Text
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

model SolutionDesign {
  id             String      @id @default(cuid())
  opportunityId  String      @unique
  opportunity    Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  ntWorkValue    Decimal     @db.Decimal(15,2)
  partnerCost    Decimal     @db.Decimal(15,2) @default(0)
  estimatedCost  Decimal     @db.Decimal(15,2)
  estimatedPrice Decimal     @db.Decimal(15,2)
  marginPct      Decimal     @db.Decimal(6,2)
  riskNotes      String?     @db.Text
  assumptions    String?     @db.Text
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model InternalOrder {
  id              String              @id @default(cuid())
  orderNo         String              @unique
  quoteId         String              @unique
  quote           Quote               @relation(fields: [quoteId], references: [id])
  status          InternalOrderStatus @default(DRAFT)
  omReference     String?
  crmReference    String?
  billingReference String?
  handoffNotes    String?             @db.Text
  sentAt          DateTime?
  acknowledgedAt  DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model QuoteItem {
  id        String  @id @default(cuid())
  quoteId   String
  quote     Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)
  unitPrice Decimal @db.Decimal(15, 2)
  createdAt DateTime @default(now())
}

model Approval {
  id        String   @id @default(cuid())
  quoteId   String
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  level     Int
  status    String   @default("PENDING")
  comment   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VendorAssessment {
  id              String        @id @default(cuid())
  opportunityId   String        @unique
  opportunity     Opportunity   @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  incumbentVendor String?
  competitors     String?       @db.Text
  approach        SalesApproach
  confidence      Int
  rationale       String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model AiProviderConfiguration {
  id              String                           @id @db.VarChar(64)
  activeVersionId String?                          @unique
  activeVersion   AiProviderConfigurationVersion? @relation("ActiveAiProviderVersion", fields: [activeVersionId], references: [id], onDelete: SetNull)
  versions        AiProviderConfigurationVersion[] @relation("AiProviderVersionHistory")
  createdAt       DateTime                         @default(now())
  updatedAt       DateTime                         @updatedAt
}

model AiProviderConfigurationVersion {
  id               String                   @id @default(cuid())
  configurationId  String                   @db.VarChar(64)
  configuration    AiProviderConfiguration  @relation("AiProviderVersionHistory", fields: [configurationId], references: [id], onDelete: Restrict)
  activeFor         AiProviderConfiguration? @relation("ActiveAiProviderVersion")
  version           Int
  enabled           Boolean                  @default(false)
  apiUrl            String                   @db.VarChar(2048)
  model             String                   @db.VarChar(255)
  requestTimeoutMs  Int
  apiKeyCiphertext  Bytes?                   @db.VarBinary(4096)
  apiKeyNonce       Bytes?                   @db.VarBinary(12)
  apiKeyAuthTag     Bytes?                   @db.VarBinary(16)
  createdAt         DateTime                 @default(now())
  aiOutputs         AiOutput[]

  @@unique([configurationId, version])
  @@index([configurationId, createdAt])
}

model AiJob {
  id              String       @id @default(cuid())
  idempotencyKey  String       @unique @db.VarChar(191)
  capability      String       @db.VarChar(100)
  requestedById   String
  requestedBy     User         @relation("AiJobRequester", fields: [requestedById], references: [id], onDelete: Restrict)
  status          AiJobStatus  @default(QUEUED)
  attemptCount    Int          @default(0)
  maxAttempts     Int
  availableAt     DateTime     @default(now())
  leaseExpiresAt  DateTime?
  errorCode       String?      @db.VarChar(100)
  startedAt       DateTime?
  completedAt     DateTime?
  output          AiOutput?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([status, availableAt])
  @@index([requestedById, capability, createdAt])
}

model AiOutput {
  id                             String                         @id @default(cuid())
  jobId                          String                         @unique
  job                            AiJob                          @relation(fields: [jobId], references: [id], onDelete: Restrict)
  providerConfigurationVersionId String
  providerConfigurationVersion   AiProviderConfigurationVersion @relation(fields: [providerConfigurationVersionId], references: [id], onDelete: Restrict)
  capability                     String                         @db.VarChar(100)
  outputSchemaVersion            String                         @db.VarChar(100)
  providerModel                  String                         @db.VarChar(255)
  promptTemplateVersion          String                         @db.VarChar(100)
  inputSourceReferences          Json
  validatedOutput                Json?
  status                         AiOutputStatus                 @default(DRAFT)
  safetyResult                   AiSafetyResult
  confidenceBand                 AiConfidenceBand              @default(UNKNOWN)
  latencyMs                      Int?
  inputTokens                    Int?
  outputTokens                   Int?
  totalTokens                    Int?
  expiresAt                      DateTime?
  legalHold                      Boolean                        @default(false)
  abandonedReason                String?                        @db.VarChar(255)
  confirmedById                  String?
  confirmedBy                    User?                          @relation("AiOutputConfirmer", fields: [confirmedById], references: [id], onDelete: Restrict)
  confirmedAt                    DateTime?
  feedback                       AiFeedback[]
  meetingDraftConfirmation       MeetingDraftConfirmation?
  createdAt                      DateTime                       @default(now())
  updatedAt                      DateTime                       @updatedAt

  @@index([status, expiresAt, legalHold])
  @@index([capability, createdAt])
  @@index([providerConfigurationVersionId])
}

model AiFeedback {
  id        String           @id @default(cuid())
  outputId  String
  output    AiOutput         @relation(fields: [outputId], references: [id], onDelete: Restrict)
  actorId   String
  actor     User             @relation("AiFeedbackActor", fields: [actorId], references: [id], onDelete: Restrict)
  rating    AiFeedbackRating
  comment   String?          @db.VarChar(1000)
  createdAt DateTime         @default(now())

  @@index([outputId, createdAt])
  @@index([actorId, createdAt])
}

model MeetingDraftConfirmation {
  id             String    @id @default(cuid())
  idempotencyKey String    @unique @db.VarChar(191)
  aiOutputId     String    @unique
  aiOutput       AiOutput  @relation(fields: [aiOutputId], references: [id], onDelete: Restrict)
  activityId     String    @unique
  activity       Activity  @relation("MeetingConfirmationActivity", fields: [activityId], references: [id], onDelete: Restrict)
  nextActionActivityId String?   @unique
  nextActionActivity   Activity? @relation("MeetingConfirmationNextAction", fields: [nextActionActivityId], references: [id], onDelete: Restrict)
  selectedFields Json
  finalContent   Json
  confirmedById  String
  confirmedBy    User      @relation("MeetingDraftConfirmer", fields: [confirmedById], references: [id], onDelete: Restrict)
  confirmedAt    DateTime
  createdAt      DateTime  @default(now())

  @@index([confirmedById, confirmedAt])
}

model AuditLedger {
  id           String   @id @db.VarChar(64)
  lastSequence BigInt   @default(0)
  lastHash     String   @db.Char(64)
  revision     Int      @default(0)
  updatedAt    DateTime @updatedAt
}

model AuditEvent {
  id            String   @id @default(cuid())
  sequence      BigInt   @unique
  actorId       String   @db.VarChar(191)
  action        String   @db.VarChar(191)
  targetType    String   @db.VarChar(191)
  targetId      String   @db.VarChar(191)
  targetVersion String?  @db.VarChar(191)
  outcome       String   @db.VarChar(32)
  correlationId String   @db.VarChar(191)
  reason        String?  @db.VarChar(1000)
  data          Json?
  previousHash  String   @db.Char(64)
  eventHash     String   @db.Char(64)
  recordedAt    DateTime @default(now())

  @@index([targetType, targetId, recordedAt])
  @@index([actorId, recordedAt])
  @@index([correlationId])
}

model DealRiskRule {
  id        String                @id @default(cuid())
  code      String                @unique @db.VarChar(100)
  versions  DealRiskRuleVersion[]
  createdAt DateTime              @default(now())
}

model DealRiskRuleVersion {
  id                String            @id @default(cuid())
  ruleId            String
  rule              DealRiskRule      @relation(fields: [ruleId], references: [id], onDelete: Restrict)
  version           Int
  riskType          String            @db.VarChar(100)
  enabled           Boolean           @default(false)
  effectiveFrom     DateTime
  effectiveTo       DateTime?
  conditionConfig   Json
  thresholdConfig   Json
  scopeConfig       Json
  severityConfig    Json
  createdById       String
  createdBy         User              @relation("DealRiskRuleVersionCreator", fields: [createdById], references: [id], onDelete: Restrict)
  signals           DealRiskSignal[]
  createdAt         DateTime          @default(now())

  @@unique([ruleId, version])
  @@index([ruleId, enabled, effectiveFrom, effectiveTo])
  @@index([riskType, enabled, effectiveFrom, effectiveTo])
}

model DealRiskSignal {
  id                   String               @id @default(cuid())
  opportunityId        String
  opportunity          Opportunity          @relation(fields: [opportunityId], references: [id], onDelete: Restrict)
  ruleVersionId        String
  ruleVersion          DealRiskRuleVersion  @relation(fields: [ruleVersionId], references: [id], onDelete: Restrict)
  evaluationKey        String               @db.VarChar(191)
  riskType             String               @db.VarChar(100)
  thresholdSnapshot    Json
  triggeringFacts      Json
  severitySnapshot     Json
  evaluatedAt          DateTime
  createdAt            DateTime             @default(now())

  @@unique([opportunityId, ruleVersionId, evaluationKey])
  @@index([opportunityId, evaluatedAt])
  @@index([ruleVersionId, evaluatedAt])
}
