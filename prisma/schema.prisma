  data          Json?
  previousHash  String   @db.Char(64)
  eventHash     String   @db.Char(64)
  recordedAt    DateTime @default(now())

  @@index([targetType, targetId, recordedAt])
  @@index([actorId, recordedAt])
  @@index([correlationId])
}

model DealRiskRule {
  id        String                @id @default(cuid())
  code      String                @unique @db.VarChar(100)
  versions  DealRiskRuleVersion[]
  createdAt DateTime              @default(now())
}

model DealRiskRuleVersion {
  id              String           @id @default(cuid())
  ruleId          String
  rule            DealRiskRule     @relation(fields: [ruleId], references: [id], onDelete: Restrict)
  version         Int
  riskType        String           @db.VarChar(100)
  enabled         Boolean          @default(false)
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  conditionConfig Json
  thresholdConfig Json
  scopeConfig     Json
  severityConfig  Json
  createdById     String
  createdBy       User             @relation("DealRiskRuleVersionCreator", fields: [createdById], references: [id], onDelete: Restrict)
  signals         DealRiskSignal[]
  createdAt       DateTime         @default(now())

  @@unique([ruleId, version])
  @@index([ruleId, enabled, effectiveFrom, effectiveTo])
  @@index([riskType, enabled, effectiveFrom, effectiveTo])
}

model DealRiskSignal {
  id                String              @id @default(cuid())
  opportunityId     String
  opportunity       Opportunity         @relation(fields: [opportunityId], references: [id], onDelete: Restrict)
  ruleVersionId     String
  ruleVersion       DealRiskRuleVersion @relation(fields: [ruleVersionId], references: [id], onDelete: Restrict)
  evaluationKey     String              @db.VarChar(191)
  riskType          String              @db.VarChar(100)
  thresholdSnapshot Json
  triggeringFacts   Json
  severitySnapshot  Json
  evaluatedAt       DateTime
  createdAt         DateTime            @default(now())

  @@unique([opportunityId, ruleVersionId, evaluationKey])
  @@index([opportunityId, evaluatedAt])
  @@index([ruleVersionId, evaluatedAt])
}

model ContractStatusDefinition {
  code              String     @id @db.VarChar(40)
  label             String     @db.VarChar(100)
  sortOrder         Int
  terminal          Boolean    @default(false)
  active            Boolean    @default(true)
  reportingCategory String     @default("OPEN") @db.VarChar(32)
  contracts         Contract[]
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([active, sortOrder])
}

model ContractStatusTransition {
  id                       String   @id @default(cuid())
  fromStatusCode           String   @db.VarChar(40)
  toStatusCode             String   @db.VarChar(40)
  requiredPermission       String?  @db.VarChar(191)
  makerChecker             Boolean  @default(false)
  requiredSignatureParties Json?
  active                   Boolean  @default(true)
  createdAt                DateTime @default(now())

  @@unique([fromStatusCode, toStatusCode])
  @@index([fromStatusCode, active])
}

model ContractTypeDefinition {
  code      String     @id @db.VarChar(60)
  name      String     @db.VarChar(150)
  active    Boolean    @default(true)
  contracts Contract[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([active, name])
}

model Contract {
  id                      String                   @id @default(cuid())
  contractNo              String                   @unique @db.VarChar(40)
  name                    String                   @db.VarChar(255)
  contractTypeCode        String                   @db.VarChar(60)
  contractType            ContractTypeDefinition   @relation(fields: [contractTypeCode], references: [code], onDelete: Restrict)
  statusCode              String                   @db.VarChar(40)
  status                  ContractStatusDefinition @relation(fields: [statusCode], references: [code], onDelete: Restrict)
  customerId              String
  customerContactId       String?
  ownerId                 String
  organizationUnitId      String?
  quoteId                 String
  quoteVersionId          String                   @unique
  opportunityId           String?
  proposalId              String?
  boqId                   String?
  siteSurveyRequestId     String?
  version                 Int                      @default(1)
  currency                String                   @default("THB") @db.Char(3)
  startDate               DateTime?
  endDate                 DateTime?
  effectiveAt             DateTime?
  autoRenewal             Boolean                  @default(false)
  nextRenewalAt           DateTime?
  totalContractValue      Decimal                  @db.Decimal(19, 4)
  monthlyRecurringRevenue Decimal                  @db.Decimal(19, 4)
  oneTimeRevenue          Decimal                  @db.Decimal(19, 4)
  deletedAt               DateTime?
  versions                ContractVersion[]
  reviews                 ContractReview[]
  documents               ContractDocument[]
  signatures              ContractSignature[]
  amendments              ContractAmendment[]
  renewals                ContractRenewal[]
  purchaseOrders          ContractPurchaseOrder[]
  serviceOrders           ContractServiceOrder[]
  commandReceipts         ContractCommandReceipt[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  @@index([ownerId, statusCode, updatedAt, id])
  @@index([customerId, statusCode, updatedAt, id])
  @@index([contractTypeCode, statusCode, updatedAt, id])
  @@index([organizationUnitId, statusCode, updatedAt, id])
  @@index([endDate, statusCode])
  @@index([nextRenewalAt, statusCode])
}

model ContractVersion {
  id                               String                 @id @default(cuid())
  contractId                       String
  contract                         Contract               @relation(fields: [contractId], references: [id], onDelete: Restrict)
  versionNumber                    Int
  statusCode                       String                 @db.VarChar(40)
  name                             String                 @db.VarChar(255)
  currency                         String                 @db.Char(3)
  startDate                        DateTime?
  endDate                          DateTime?
  paymentTerm                      String?                @db.VarChar(255)
  billingCycle                     String?                @db.VarChar(100)
  taxRate                          Decimal                @default(0) @db.Decimal(7, 4)
  subtotal                         Decimal                @db.Decimal(19, 4)
  discountAmount                   Decimal                @db.Decimal(19, 4)
  taxAmount                        Decimal                @db.Decimal(19, 4)
  totalWithTax                     Decimal                @db.Decimal(19, 4)
  totalContractValue               Decimal                @db.Decimal(19, 4)
  monthlyRecurringRevenue          Decimal                @db.Decimal(19, 4)
  oneTimeRevenue                   Decimal                @db.Decimal(19, 4)
  annualRecurringRevenue           Decimal                @db.Decimal(19, 4)
  terms                            String?                @db.LongText
  remarks                          String?                @db.Text
  sourceSnapshot                   Json
  changeReason                     String?                @db.VarChar(1000)
  amendmentId                      String?
  aiProviderConfigurationVersionId String?
  aiProviderModel                  String?                @db.VarChar(255)
  aiPromptTemplateVersion          String?                @db.VarChar(100)
  aiInputSourceReferences          Json?
  createdById                      String
  items                            ContractItem[]
  reviews                          ContractReview[]
  signatures                       ContractSignature[]
  serviceOrders                    ContractServiceOrder[]
  createdAt                        DateTime               @default(now())

  @@unique([contractId, versionNumber])
  @@index([contractId, createdAt])
  @@index([amendmentId])
}

model ContractItem {
  id                         String          @id @default(cuid())
  contractVersionId          String
  contractVersion            ContractVersion @relation(fields: [contractVersionId], references: [id], onDelete: Restrict)
  productId                  String?
  productCode                String          @db.VarChar(191)
  serviceName                String          @db.VarChar(255)
  description                String?         @db.Text
  quantity                   Decimal         @db.Decimal(19, 4)
  unit                       String          @db.VarChar(50)
  monthlyCharge              Decimal         @db.Decimal(19, 4)
  oneTimeCharge              Decimal         @db.Decimal(19, 4)
  discountAmount             Decimal         @db.Decimal(19, 4)
  durationMonths             Int
  lineContractValue          Decimal         @db.Decimal(19, 4)
  installationRequired       Boolean         @default(false)
  solutionInstallationSiteId String?
  serviceLocation            String?         @db.VarChar(500)
  bandwidth                  String?         @db.VarChar(100)
  sla                        String?         @db.VarChar(255)
  supportLevel               String?         @db.VarChar(255)
  futureCircuitId            String?         @db.VarChar(191)
  futureServiceId            String?         @db.VarChar(191)
  sortOrder                  Int
  createdAt                  DateTime        @default(now())

  @@index([contractVersionId, sortOrder])
  @@index([productId])
  @@index([solutionInstallationSiteId])
}

model ContractReview {
  id                String          @id @default(cuid())
  contractId        String
  contract          Contract        @relation(fields: [contractId], references: [id], onDelete: Restrict)
  contractVersionId String
  contractVersion   ContractVersion @relation(fields: [contractVersionId], references: [id], onDelete: Restrict)
  reviewType        String          @db.VarChar(50)
  status            String          @db.VarChar(40)
  reviewerId        String
  riskLevel         String?         @db.VarChar(40)
  clauses           Json?
  comment           String?         @db.Text
  decidedAt         DateTime?
  createdAt         DateTime        @default(now())

  @@index([contractId, reviewType, status, createdAt])
}

model ContractDocument {
  id             String                    @id @default(cuid())
  contractId     String
  contract       Contract                  @relation(fields: [contractId], references: [id], onDelete: Restrict)
  category       String                    @db.VarChar(60)
  currentVersion Int                       @default(0)
  versions       ContractDocumentVersion[]
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  @@index([contractId, category, updatedAt])
}

model ContractDocumentVersion {
  id                String                  @id @default(cuid())
  documentId        String
  document          ContractDocument        @relation(fields: [documentId], references: [id], onDelete: Restrict)
  versionNumber     Int
  fileName          String                  @db.VarChar(255)
  mimeType          String                  @db.VarChar(191)
  sizeBytes         BigInt
  objectKey         String                  @db.Text
  objectKeyHash     String                  @unique @db.Char(64)
  sha256            String                  @db.Char(64)
  malwareScanStatus String                  @db.VarChar(40)
  uploadedById      String
  createdAt         DateTime                @default(now())
  signatures        ContractSignature[]
  purchaseOrders    ContractPurchaseOrder[]

  @@unique([documentId, versionNumber])
  @@index([documentId, createdAt])
}

model ContractSignature {
  id                String                  @id @default(cuid())
  contractId        String
  contract          Contract                @relation(fields: [contractId], references: [id], onDelete: Restrict)
  contractVersionId String
  contractVersion   ContractVersion         @relation(fields: [contractVersionId], references: [id], onDelete: Restrict)
  partyCode         String                  @db.VarChar(40)
  methodCode        String                  @db.VarChar(40)
  status            String                  @db.VarChar(40)
  documentVersionId String
  documentVersion   ContractDocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Restrict)
  signedByName      String                  @db.VarChar(255)
  signedAt          DateTime
  verifiedById      String
  providerReference String?                 @db.VarChar(255)
  createdAt         DateTime                @default(now())

  @@unique([contractVersionId, partyCode])
  @@index([contractId, status, signedAt])
}

model ContractAmendment {
  id                     String    @id @default(cuid())
  contractId             String
  contract               Contract  @relation(fields: [contractId], references: [id], onDelete: Restrict)
  amendmentNo            String    @db.VarChar(60)
  amendmentTypeCode      String    @db.VarChar(60)
  status                 String    @db.VarChar(40)
  reason                 String    @db.VarChar(1000)
  sourceVersionNumber    Int
  resultingVersionNumber Int?
  requestedById          String
  approvedAt             DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@unique([contractId, amendmentNo])
  @@index([contractId, status, createdAt])
}

model ContractRenewal {
  id                String                    @id @default(cuid())
  contractId        String
  contract          Contract                  @relation(fields: [contractId], references: [id], onDelete: Restrict)
  renewalTypeCode   String                    @db.VarChar(60)
  status            String                    @db.VarChar(40)
  renewalDate       DateTime
  outcome           String?                   @db.VarChar(100)
  renewedContractId String?
  createdById       String
  reminders         ContractRenewalReminder[]
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([renewalDate, status])
  @@index([contractId, status, renewalDate])
}

model ContractRenewalReminder {
  id         String          @id @default(cuid())
  renewalId  String
  renewal    ContractRenewal @relation(fields: [renewalId], references: [id], onDelete: Restrict)
  daysBefore Int
  dueAt      DateTime
  status     String          @default("PENDING") @db.VarChar(40)
  sentAt     DateTime?
  createdAt  DateTime        @default(now())

  @@unique([renewalId, daysBefore])
  @@index([status, dueAt])
}

model ContractPurchaseOrder {
  id                String                   @id @default(cuid())
  contractId        String
  contract          Contract                 @relation(fields: [contractId], references: [id], onDelete: Restrict)
  poNumber          String                   @db.VarChar(100)
  poDate            DateTime
  currency          String                   @db.Char(3)
  amount            Decimal                  @db.Decimal(19, 4)
  remainingAmount   Decimal                  @db.Decimal(19, 4)
  documentVersionId String?
  documentVersion   ContractDocumentVersion? @relation(fields: [documentVersionId], references: [id], onDelete: Restrict)
  createdById       String
  createdAt         DateTime                 @default(now())

  @@unique([contractId, poNumber])
  @@index([contractId, poDate])
}

model ContractServiceOrder {
  id                String          @id @default(cuid())
  contractId        String
  contract          Contract        @relation(fields: [contractId], references: [id], onDelete: Restrict)
  contractVersionId String
  contractVersion   ContractVersion @relation(fields: [contractVersionId], references: [id], onDelete: Restrict)
  orderNo           String          @unique @db.VarChar(60)
  modeCode          String          @default("MANUAL") @db.VarChar(40)
  status            String          @db.VarChar(40)
  prefillSnapshot   Json
  createdById       String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([contractId, status, createdAt])
}

model ContractCommandReceipt {
  id             String   @id @default(cuid())
  actorId        String
  idempotencyKey String   @db.VarChar(191)
  command        String   @db.VarChar(100)
  contractId     String
  contract       Contract @relation(fields: [contractId], references: [id], onDelete: Restrict)
  resultVersion  Int
  createdAt      DateTime @default(now())

  @@unique([actorId, idempotencyKey, command])
  @@index([contractId, createdAt])
}

model ContractNumberSequence {
  id        String   @id @db.VarChar(32)
  nextValue Int      @default(0)
  updatedAt DateTime @updatedAt
}
