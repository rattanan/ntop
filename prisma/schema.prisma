  id               String                @id @default(cuid())
  quoteVersionId   String
  quoteVersion     QuoteVersion          @relation(fields: [quoteVersionId], references: [id], onDelete: Restrict)
  policyVersionId  String
  policyVersion    ApprovalPolicyVersion @relation(fields: [policyVersionId], references: [id], onDelete: Restrict)
  makerId          String
  maker            User                  @relation("ApprovalRequestMaker", fields: [makerId], references: [id], onDelete: Restrict)
  status           ApprovalRequestStatus @default(PENDING)
  version          Int                   @default(1)
  inputSnapshot    Json
  quoteVersionHash String                @db.Char(64)
  submittedAt      DateTime
  completedAt      DateTime?
  supersededAt     DateTime?
  steps            ApprovalStep[]
  decisions        ApprovalDecision[]

  @@index([quoteVersionId, status])
  @@index([makerId, submittedAt])
}

model ApprovalStep {
  id                 String             @id @default(cuid())
  requestId          String
  request            ApprovalRequest    @relation(fields: [requestId], references: [id], onDelete: Restrict)
  stepCode           String             @db.VarChar(100)
  sequence           Int
  executionMode      String             @db.VarChar(32)
  requiredPermission String             @db.VarChar(191)
  assignedRoleCode   String?            @db.VarChar(100)
  delegatedToActorId String?
  minimumAuthority   Decimal?           @db.Decimal(19, 4)
  maximumAuthority   Decimal?           @db.Decimal(19, 4)
  makerChecker       Boolean            @default(true)
  status             ApprovalStepStatus @default(WAITING)
  dueAt              DateTime?
  decisions          ApprovalDecision[]

  @@unique([requestId, stepCode])
  @@index([requestId, sequence, status])
}

model ApprovalDecision {
  id                  String          @id @default(cuid())
  requestId           String
  request             ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Restrict)
  stepId              String
  step                ApprovalStep    @relation(fields: [stepId], references: [id], onDelete: Restrict)
  actorId             String
  actor               User            @relation("ApprovalDecisionActor", fields: [actorId], references: [id], onDelete: Restrict)
  delegateToActorId   String?
  decision            String          @db.VarChar(32)
  reason              String          @db.VarChar(1000)
  authoritySnapshot   Json
  policyInputSnapshot Json
  previousHash        String          @db.Char(64)
  decisionHash        String          @db.Char(64)
  correlationId       String          @db.VarChar(191)
  decidedAt           DateTime

  @@index([requestId, decidedAt])
  @@index([actorId, decidedAt])
}

model CommercialCommandReceipt {
  id             String   @id @default(cuid())
  actorId        String
  actor          User     @relation(fields: [actorId], references: [id], onDelete: Restrict)
  idempotencyKey String   @db.VarChar(191)
  command        String   @db.VarChar(100)
  targetId       String   @db.VarChar(191)
  resultVersion  Int?
  createdAt      DateTime @default(now())

  @@unique([actorId, idempotencyKey, command])
  @@index([targetId, createdAt])
}

model ForecastSnapshot {
  id              String         @id @default(cuid())
  snapshotKey     String         @unique @db.VarChar(191)
  periodStart     DateTime
  periodEnd       DateTime
  cutoffAt        DateTime
  timezone        String         @db.VarChar(64)
  formulaVersion  String         @db.VarChar(64)
  scopeSnapshot   Json
  currency        String         @default("THB") @db.Char(3)
  pipelineAmount  Decimal        @db.Decimal(19, 4)
  weightedAmount  Decimal        @db.Decimal(19, 4)
  qualitySnapshot Json
  createdById     String
  createdAt       DateTime       @default(now())
  items           ForecastItem[]

  @@index([periodStart, periodEnd, cutoffAt])
}

model ForecastItem {
  id                   String           @id @default(cuid())
  snapshotId           String
  snapshot             ForecastSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Restrict)
  opportunityId        String
  opportunity          Opportunity      @relation(fields: [opportunityId], references: [id], onDelete: Restrict)
  opportunityVersion   Int
  ownerId              String
  organizationUnitId   String?
  customerId           String
  segment              String           @db.VarChar(100)
  flow                 String           @db.VarChar(191)
  stage                OpportunityStage
  category             ForecastCategory
  estimatedValue       Decimal          @db.Decimal(19, 4)
  forecastAmount       Decimal          @db.Decimal(19, 4)
  weightedAmount       Decimal          @db.Decimal(19, 4)
  probability          Int
  amountSource         String           @db.VarChar(32)
  sourceQuoteVersionId String?
  expectedCloseAt      DateTime?
  stageEnteredAt       DateTime
  riskSnapshot         Json
  qualitySnapshot      Json

  @@unique([snapshotId, opportunityId])
  @@index([snapshotId, organizationUnitId, ownerId, stage, category])
}

model FiscalCalendar {
  id                   String    @id @default(cuid())
  code                 String    @unique @db.VarChar(100)
  name                 String    @db.VarChar(255)
  fiscalYearStartMonth Int
  timezone             String    @db.VarChar(64)
  currency             String    @db.Char(3)
  reportingCutoffHour  Int
  submissionSchedule   Json
  lockSchedule         Json
  active               Boolean   @default(true)
  effectiveFrom        DateTime
  effectiveTo          DateTime?
  createdById          String
  createdBy            User      @relation("FiscalCalendarCreator", fields: [createdById], references: [id], onDelete: Restrict)
  updatedById          String
  updatedBy            User      @relation("FiscalCalendarUpdater", fields: [updatedById], references: [id], onDelete: Restrict)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([active, effectiveFrom, effectiveTo])
}

model SalesTarget {
  id                     String            @id @default(cuid())
  version                Int               @default(1)
  targetType             String            @db.VarChar(64)
  scopeKey               String            @db.VarChar(191)
  userId                 String?
  user                   User?             @relation("SalesTargetAssignee", fields: [userId], references: [id], onDelete: Restrict)
  teamId                 String?
  team                   OrganizationUnit? @relation("SalesTargetTeam", fields: [teamId], references: [id], onDelete: Restrict)
  departmentId           String?
  department             OrganizationUnit? @relation("SalesTargetDepartment", fields: [departmentId], references: [id], onDelete: Restrict)
  businessUnitId         String?
  businessUnit           OrganizationUnit? @relation("SalesTargetBusinessUnit", fields: [businessUnitId], references: [id], onDelete: Restrict)
  territoryId            String?
  territory              SalesTerritory?   @relation(fields: [territoryId], references: [id], onDelete: Restrict)
  region                 String?           @db.VarChar(100)
  productCategoryId      String?           @db.VarChar(191)
  customerSegment        String?           @db.VarChar(100)
  revenueType            RevenueType
  periodType             FiscalPeriodType
  fiscalYear             Int
  fiscalQuarter          Int?
  fiscalMonth            Int?
  targetAmount           Decimal           @db.Decimal(19, 4)
  targetGrossProfit      Decimal?          @db.Decimal(19, 4)
  targetRecurringRevenue Decimal?          @db.Decimal(19, 4)
  currency               String            @db.Char(3)
  status                 SalesTargetStatus @default(DRAFT)
  effectiveFrom          DateTime
  effectiveTo            DateTime?
  createdById            String
  createdBy              User              @relation("SalesTargetCreator", fields: [createdById], references: [id], onDelete: Restrict)
  updatedById            String
  updatedBy              User              @relation("SalesTargetUpdater", fields: [updatedById], references: [id], onDelete: Restrict)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  @@index([scopeKey, status, effectiveFrom, effectiveTo])
  @@index([userId, fiscalYear, periodType, status])
  @@index([teamId, fiscalYear, periodType, status])
  @@index([businessUnitId, fiscalYear, periodType, status])
  @@index([territoryId, fiscalYear, periodType, status])
}

model CoverageCheck {
  id                  String         @id @default(cuid())
  opportunityId       String
  opportunity         Opportunity    @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  siteAddress         String         @db.Text
  circuitCount        Int            @default(1)
  status              CoverageStatus @default(DRAFT)
  fiberAvailable      Boolean?
  olt                 String?
  distanceKm          Decimal?       @db.Decimal(10, 2)
  capacityMbps        Int?
  availablePorts      Int?
  expectedInstallDate DateTime?
  confirmedCost       Decimal?       @db.Decimal(15, 2)
  responderNotes      String?        @db.Text
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

model SolutionDesign {
  id             String      @id @default(cuid())
  opportunityId  String      @unique
  opportunity    Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  ntWorkValue    Decimal     @db.Decimal(15, 2)
  partnerCost    Decimal     @default(0) @db.Decimal(15, 2)
  estimatedCost  Decimal     @db.Decimal(15, 2)
  estimatedPrice Decimal     @db.Decimal(15, 2)
  marginPct      Decimal     @db.Decimal(6, 2)
  riskNotes      String?     @db.Text
  assumptions    String?     @db.Text
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model InternalOrder {
  id               String              @id @default(cuid())
  orderNo          String              @unique
  quoteId          String              @unique
  quote            Quote               @relation(fields: [quoteId], references: [id])
  status           InternalOrderStatus @default(DRAFT)
  omReference      String?
  crmReference     String?
  billingReference String?
  handoffNotes     String?             @db.Text
  sentAt           DateTime?
  acknowledgedAt   DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model QuoteItem {
  id        String   @id @default(cuid())
  quoteId   String
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(1)
  unitPrice Decimal  @db.Decimal(15, 2)
  createdAt DateTime @default(now())
}

model Approval {
  id        String   @id @default(cuid())
  quoteId   String
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  level     Int
  status    String   @default("PENDING")
  comment   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VendorAssessment {
  id              String        @id @default(cuid())
  opportunityId   String        @unique
  opportunity     Opportunity   @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  incumbentVendor String?
  competitors     String?       @db.Text
  approach        SalesApproach
  confidence      Int
  rationale       String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model AiProviderConfiguration {
  id              String                           @id @db.VarChar(64)
  activeVersionId String?                          @unique
  activeVersion   AiProviderConfigurationVersion?  @relation("ActiveAiProviderVersion", fields: [activeVersionId], references: [id], onDelete: SetNull)
  versions        AiProviderConfigurationVersion[] @relation("AiProviderVersionHistory")
  createdAt       DateTime                         @default(now())
  updatedAt       DateTime                         @updatedAt
}

model AiProviderConfigurationVersion {
  id               String                   @id @default(cuid())
  configurationId  String                   @db.VarChar(64)
  configuration    AiProviderConfiguration  @relation("AiProviderVersionHistory", fields: [configurationId], references: [id], onDelete: Restrict)
  activeFor        AiProviderConfiguration? @relation("ActiveAiProviderVersion")
  version          Int
  enabled          Boolean                  @default(false)
  apiUrl           String                   @db.VarChar(2048)
  model            String                   @db.VarChar(255)
  requestTimeoutMs Int
  apiKeyCiphertext Bytes?                   @db.VarBinary(4096)
  apiKeyNonce      Bytes?                   @db.VarBinary(12)
  apiKeyAuthTag    Bytes?                   @db.VarBinary(16)
  createdAt        DateTime                 @default(now())
  aiOutputs        AiOutput[]

  @@unique([configurationId, version])
  @@index([configurationId, createdAt])
}

model AiJob {
  id             String      @id @default(cuid())
  idempotencyKey String      @unique @db.VarChar(191)
  capability     String      @db.VarChar(100)
  requestedById  String
  requestedBy    User        @relation("AiJobRequester", fields: [requestedById], references: [id], onDelete: Restrict)
  status         AiJobStatus @default(QUEUED)
  attemptCount   Int         @default(0)
  maxAttempts    Int
  availableAt    DateTime    @default(now())
  leaseExpiresAt DateTime?
  errorCode      String?     @db.VarChar(100)
  startedAt      DateTime?
  completedAt    DateTime?
  output         AiOutput?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([status, availableAt])
  @@index([requestedById, capability, createdAt])
}

model AiOutput {
  id                             String                         @id @default(cuid())
  jobId                          String                         @unique
  job                            AiJob                          @relation(fields: [jobId], references: [id], onDelete: Restrict)
  providerConfigurationVersionId String
  providerConfigurationVersion   AiProviderConfigurationVersion @relation(fields: [providerConfigurationVersionId], references: [id], onDelete: Restrict)
  capability                     String                         @db.VarChar(100)
  outputSchemaVersion            String                         @db.VarChar(100)
  providerModel                  String                         @db.VarChar(255)
  promptTemplateVersion          String                         @db.VarChar(100)
  inputSourceReferences          Json
  validatedOutput                Json?
  status                         AiOutputStatus                 @default(DRAFT)
  safetyResult                   AiSafetyResult
  confidenceBand                 AiConfidenceBand               @default(UNKNOWN)
  latencyMs                      Int?
  inputTokens                    Int?
  outputTokens                   Int?
  totalTokens                    Int?
  expiresAt                      DateTime?
  legalHold                      Boolean                        @default(false)
  abandonedReason                String?                        @db.VarChar(255)
  confirmedById                  String?
  confirmedBy                    User?                          @relation("AiOutputConfirmer", fields: [confirmedById], references: [id], onDelete: Restrict)
  confirmedAt                    DateTime?
  feedback                       AiFeedback[]
  meetingDraftConfirmation       MeetingDraftConfirmation?
  createdAt                      DateTime                       @default(now())
  updatedAt                      DateTime                       @updatedAt

  @@index([status, expiresAt, legalHold])
  @@index([capability, createdAt])
  @@index([providerConfigurationVersionId])
}

model AiFeedback {
  id        String           @id @default(cuid())
  outputId  String
  output    AiOutput         @relation(fields: [outputId], references: [id], onDelete: Restrict)
  actorId   String
  actor     User             @relation("AiFeedbackActor", fields: [actorId], references: [id], onDelete: Restrict)
  rating    AiFeedbackRating
  comment   String?          @db.VarChar(1000)
  createdAt DateTime         @default(now())

  @@index([outputId, createdAt])
  @@index([actorId, createdAt])
}

model MeetingDraftConfirmation {
  id                   String    @id @default(cuid())
  idempotencyKey       String    @unique @db.VarChar(191)
  aiOutputId           String    @unique
  aiOutput             AiOutput  @relation(fields: [aiOutputId], references: [id], onDelete: Restrict)
  activityId           String    @unique
  activity             Activity  @relation("MeetingConfirmationActivity", fields: [activityId], references: [id], onDelete: Restrict)
  nextActionActivityId String?   @unique
  nextActionActivity   Activity? @relation("MeetingConfirmationNextAction", fields: [nextActionActivityId], references: [id], onDelete: Restrict)
  selectedFields       Json
  finalContent         Json
  confirmedById        String
  confirmedBy          User      @relation("MeetingDraftConfirmer", fields: [confirmedById], references: [id], onDelete: Restrict)
  confirmedAt          DateTime
  createdAt            DateTime  @default(now())

  @@index([confirmedById, confirmedAt])
}

model AuditLedger {
  id           String   @id @db.VarChar(64)
  lastSequence BigInt   @default(0)
  lastHash     String   @db.Char(64)
  revision     Int      @default(0)
  updatedAt    DateTime @updatedAt
}

model AuditEvent {
  id            String   @id @default(cuid())
  sequence      BigInt   @unique
  actorId       String   @db.VarChar(191)
  action        String   @db.VarChar(191)
  targetType    String   @db.VarChar(191)
  targetId      String   @db.VarChar(191)
  targetVersion String?  @db.VarChar(191)
  outcome       String   @db.VarChar(32)
  correlationId String   @db.VarChar(191)
  reason        String?  @db.VarChar(1000)
  data          Json?
  previousHash  String   @db.Char(64)
  eventHash     String   @db.Char(64)
  recordedAt    DateTime @default(now())

  @@index([targetType, targetId, recordedAt])
  @@index([actorId, recordedAt])
  @@index([correlationId])
}

model DealRiskRule {
  id        String                @id @default(cuid())
  code      String                @unique @db.VarChar(100)
  versions  DealRiskRuleVersion[]
  createdAt DateTime              @default(now())
}

model DealRiskRuleVersion {
  id              String           @id @default(cuid())
  ruleId          String
  rule            DealRiskRule     @relation(fields: [ruleId], references: [id], onDelete: Restrict)
  version         Int
  riskType        String           @db.VarChar(100)
  enabled         Boolean          @default(false)
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  conditionConfig Json
  thresholdConfig Json
  scopeConfig     Json
  severityConfig  Json
  createdById     String
  createdBy       User             @relation("DealRiskRuleVersionCreator", fields: [createdById], references: [id], onDelete: Restrict)
  signals         DealRiskSignal[]
  createdAt       DateTime         @default(now())

  @@unique([ruleId, version])
  @@index([ruleId, enabled, effectiveFrom, effectiveTo])
  @@index([riskType, enabled, effectiveFrom, effectiveTo])
}

model DealRiskSignal {
  id                String              @id @default(cuid())
  opportunityId     String
  opportunity       Opportunity         @relation(fields: [opportunityId], references: [id], onDelete: Restrict)
  ruleVersionId     String
  ruleVersion       DealRiskRuleVersion @relation(fields: [ruleVersionId], references: [id], onDelete: Restrict)
  evaluationKey     String              @db.VarChar(191)
  riskType          String              @db.VarChar(100)
  thresholdSnapshot Json
  triggeringFacts   Json
  severitySnapshot  Json
  evaluatedAt       DateTime
  createdAt         DateTime            @default(now())

  @@unique([opportunityId, ruleVersionId, evaluationKey])
  @@index([opportunityId, evaluatedAt])
  @@index([ruleVersionId, evaluatedAt])
}
