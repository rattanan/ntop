generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SALES
  VIEWER
}

enum LoginOutcome {
  SUCCESS
  INVALID_CREDENTIALS
  DISABLED
}

enum CustomerType {
  B2G
  B2B
}

enum CustomerStatus {
  PROSPECT
  ACTIVE
  INACTIVE
  BLACKLISTED
  CLOSED
}

enum OpportunityStage {
  QUALIFY
  DISCOVER
  SOLUTION
  PROPOSAL
  NEGOTIATION
  WON
  LOST
  CANCELLED
  EXPIRED
}

enum ForecastCategory {
  COMMIT
  BEST_CASE
  PIPELINE
  OMITTED
}

enum FiscalPeriodType {
  MONTH
  QUARTER
  YEAR
}

enum SalesTargetStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum RevenueType {
  TOTAL_REVENUE
  ONE_TIME_REVENUE
  MONTHLY_RECURRING_REVENUE
  ANNUAL_RECURRING_REVENUE
  TOTAL_CONTRACT_VALUE
  GROSS_PROFIT
}

enum QuoteVersionStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  RETURNED
  SENT
  ACCEPTED
  SUPERSEDED
}

enum ApprovalRequestStatus {
  PENDING
  PENDING_ESCALATION
  APPROVED
  REJECTED
  RETURNED
  CANCELLED
  EXPIRED
  SUPERSEDED
}

enum ApprovalStepStatus {
  WAITING
  PENDING
  APPROVED
  REJECTED
  RETURNED
  DELEGATED
  ESCALATED
  SKIPPED
}

enum SalesApproach {
  DIRECT
  PARTNER
  DISPLACE
}

enum LeadSource {
  IMPORT
  WEBSITE
  EVENT
  PARTNER
  REFERRAL
  EXISTING_CUSTOMER
  MARKETING_CAMPAIGN
  API
  GOVERNMENT_TENDER
}

enum LeadStatus {
  NEW
  ASSIGNED
  CONTACTED
  QUALIFIED
  NURTURING
  CONVERTED
  DISQUALIFIED
  INVALID
  DUPLICATE
  NOT_INTERESTED
  NO_BUDGET
  ARCHIVED
}

enum LeadType {
  CORPORATE
  GOVERNMENT
  SME
  PARTNER
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum LeadTemperature {
  COLD
  WARM
  HOT
}

enum LeadAssignmentStrategy {
  OWNER
  ROUND_ROBIN
}

enum ActivityType {
  CALL
  PHONE_CALL
  EMAIL
  LINE
  MEETING
  SITE_VISIT
  CUSTOMER_VISIT
  ONLINE_MEETING
  VIDEO_CONFERENCE
  DEMO
  PRESENTATION
  NOTE
  FOLLOW_UP
  TASK
  DOCUMENT_REQUEST
  OTHER
}

enum ProspectStatus {
  NEW
  ASSIGNED
  CONTACTED
  INTERESTED
  QUALIFYING
  QUALIFIED
  NOT_INTERESTED
  UNREACHABLE
  LOST
  CONVERTED
  ARCHIVED
}

enum ProspectSource {
  MANUAL
  WEBSITE
  LINE_OA
  CALL_CENTER
  WALK_IN
  EVENT
  PARTNER
  REFERRAL
  EXISTING_CUSTOMER
  TENDER
  GOVERNMENT_PROJECT
  WEB_SCRAPER
  COMPANY_REGISTRY
  IMPORT
  OTHER
}

enum ProspectHeatLevel {
  HOT
  WARM
  COLD
}

enum ProspectEnrichmentStatus {
  NOT_REQUESTED
  QUEUED
  PROCESSING
  READY
  CONFIRMED
  REJECTED
  FAILED
}

enum ProspectContactChannel {
  PHONE
  MOBILE
  EMAIL
  LINE
  MEETING
  OTHER
}

enum ProspectImportRowStatus {
  VALID
  WARNING
  DUPLICATE
  ERROR
  IMPORTED
}

enum ProspectImportBatchStatus {
  PREVIEWED
  PROCESSING
  COMPLETED
  PARTIAL
  FAILED
}

enum QuoteStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SENT
  ACCEPTED
  EXPIRED
}

enum CoverageStatus {
  DRAFT
  REQUESTED
  CONFIRMED
  UNAVAILABLE
  RETURNED
}

enum InternalOrderStatus {
  DRAFT
  READY_FOR_HANDOFF
  SENT
  ACKNOWLEDGED
  RETURNED
  COMPLETED
}

enum AiJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum AiOutputStatus {
  DRAFT
  CONFIRMED
  REJECTED
  ABANDONED
}

enum AiSafetyResult {
  PASSED
  REJECTED
  REVIEW_REQUIRED
}

enum AiConfidenceBand {
  LOW
  MEDIUM
  HIGH
  UNKNOWN
}

enum AiFeedbackRating {
  HELPFUL
  INCORRECT
  UNSAFE
}

model User {
  id                              String                             @id @default(cuid())
  email                           String                             @unique
  name                            String
  passwordHash                    String
  role                            Role                               @default(SALES)
  active                          Boolean                            @default(true)
  ownedCustomers                  Customer[]                         @relation("CustomerOwner")
  ownedDeals                      Opportunity[]                      @relation("OpportunityOwner")
  ownedLeads                      Lead[]                             @relation("LeadOwner")
  activities                      Activity[]                         @relation("ActivityOwner")
  requestedAiJobs                 AiJob[]                            @relation("AiJobRequester")
  confirmedAiOutputs              AiOutput[]                         @relation("AiOutputConfirmer")
  aiFeedback                      AiFeedback[]                       @relation("AiFeedbackActor")
  createdRiskRuleVersions         DealRiskRuleVersion[]              @relation("DealRiskRuleVersionCreator")
  confirmedMeetingDrafts          MeetingDraftConfirmation[]         @relation("MeetingDraftConfirmer")
  customerOwnershipAssignments    CustomerOwnershipAssignment[]      @relation("CustomerOwnershipAssignee")
  assignedCustomerOwnerships      CustomerOwnershipAssignment[]      @relation("CustomerOwnershipActor")
  customerMergeActions            CustomerMergeHistory[]             @relation("CustomerMergeActor")
  customerCommandReceipts         CustomerCommandReceipt[]
  leadCommandReceipts             LeadCommandReceipt[]
  leadStatusActions               LeadStatusHistory[]                @relation("LeadStatusActor")
  leadAssignmentActions           LeadAssignmentHistory[]            @relation("LeadAssignmentActor")
  savedLeadViews                  LeadSavedView[]
  targetedLeadRules               LeadAssignmentRule[]               @relation("LeadRuleTargetOwner")
  ownedProspects                  Prospect[]                         @relation("ProspectOwner")
  backupOwnedProspects            Prospect[]                         @relation("ProspectBackupOwner")
  managedProspects                Prospect[]                         @relation("ProspectSalesManager")
  opportunityStageActions         OpportunityStageHistory[]          @relation("OpportunityStageActor")
  opportunityProbabilityActions   OpportunityProbabilityHistory[]    @relation("OpportunityProbabilityActor")
  opportunityCommandReceipts      OpportunityCommandReceipt[]
  opportunityRelatedReceipts      OpportunityRelatedCommandReceipt[]
  ownedOpportunityPainPoints      OpportunityPainPoint[]             @relation("OpportunityPainPointOwner")
  madeQuotes                      Quote[]                            @relation("QuoteMaker")
  ownedProposals                  Proposal[]                         @relation("ProposalOwner")
  createdProposalVersions         ProposalVersion[]                  @relation("ProposalVersionCreator")
  createdProposalTemplates        ProposalTemplate[]                 @relation("ProposalTemplateCreator")
  createdProposalTemplateVersions ProposalTemplateVersion[]          @relation("ProposalTemplateVersionCreator")
  proposalCommandReceipts         ProposalCommandReceipt[]
  approvalRequestsMade            ApprovalRequest[]                  @relation("ApprovalRequestMaker")
  approvalDecisions               ApprovalDecision[]                 @relation("ApprovalDecisionActor")
  commercialCommandReceipts       CommercialCommandReceipt[]
  fiscalCalendarsCreated          FiscalCalendar[]                   @relation("FiscalCalendarCreator")
  fiscalCalendarsUpdated          FiscalCalendar[]                   @relation("FiscalCalendarUpdater")
  assignedSalesTargets            SalesTarget[]                      @relation("SalesTargetAssignee")
  salesTargetsCreated             SalesTarget[]                      @relation("SalesTargetCreator")
  salesTargetsUpdated             SalesTarget[]                      @relation("SalesTargetUpdater")
  enterpriseRoleAssignments       UserRoleAssignment[]
  loginEvents                     LoginEvent[]
  createdAt                       DateTime                           @default(now())
  updatedAt                       DateTime                           @updatedAt
}

model LoginEvent {
  id             String       @id @default(cuid())
  userId         String?
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  identifierHash String       @db.Char(64)
  outcome        LoginOutcome
  ipAddressHash  String?      @db.Char(64)
  userAgentHash  String?      @db.Char(64)
  correlationId  String       @db.VarChar(191)
  occurredAt     DateTime     @default(now())

  @@index([occurredAt, outcome])
  @@index([userId, occurredAt])
  @@index([identifierHash, occurredAt])
  @@index([correlationId])
}

model Customer {
  id                        String                        @id @default(cuid())
  name                      String
  taxId                     String                        @unique
  type                      CustomerType
  segment                   String
  province                  String
  address                   String?                       @db.Text
  status                    CustomerStatus                @default(PROSPECT)
  ownerId                   String
  owner                     User                          @relation("CustomerOwner", fields: [ownerId], references: [id])
  version                   Int                           @default(1)
  organizationUnitId        String?
  organizationUnit          OrganizationUnit?             @relation(fields: [organizationUnitId], references: [id], onDelete: SetNull)
  contacts                  Contact[]
  externalIds               CustomerExternalId[]
  parentRelationships       CustomerRelationship[]        @relation("CustomerRelationshipParent")
  childRelationships        CustomerRelationship[]        @relation("CustomerRelationshipChild")
  ownershipHistory          CustomerOwnershipAssignment[]
  mergedIntoCustomerId      String?
  mergedIntoCustomer        Customer?                     @relation("CustomerMergeAliases", fields: [mergedIntoCustomerId], references: [id], onDelete: Restrict)
  mergeAliases              Customer[]                    @relation("CustomerMergeAliases")
  mergeSourceHistory        CustomerMergeHistory[]        @relation("CustomerMergeSource")
  mergeTargetHistory        CustomerMergeHistory[]        @relation("CustomerMergeTarget")
  duplicateCandidatesA      CustomerDuplicateCandidate[]  @relation("CustomerDuplicateA")
  duplicateCandidatesB      CustomerDuplicateCandidate[]  @relation("CustomerDuplicateB")
  duplicateMergeTargets     CustomerDuplicateCandidate[]  @relation("CustomerDuplicateMergeTarget")
  opportunities             Opportunity[]
  leads                     Lead[]
  activities                Activity[]
  quotes                    Quote[]
  proposals                 Proposal[]
  solutionInstallationSites SolutionInstallationSite[]
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt

  @@index([organizationUnitId, updatedAt])
  @@index([ownerId, updatedAt])
  @@index([status, updatedAt, id])
  @@index([segment, updatedAt, id])
  @@index([mergedIntoCustomerId])
}

model CustomerExternalId {
  id           String   @id @default(cuid())
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  sourceSystem String   @db.VarChar(100)
  externalId   String   @db.VarChar(255)
  createdAt    DateTime @default(now())

  @@unique([sourceSystem, externalId])
  @@index([customerId, sourceSystem])
}

model CustomerRelationship {
  id               String    @id @default(cuid())
  parentCustomerId String
  parentCustomer   Customer  @relation("CustomerRelationshipParent", fields: [parentCustomerId], references: [id], onDelete: Restrict)
  childCustomerId  String
  childCustomer    Customer  @relation("CustomerRelationshipChild", fields: [childCustomerId], references: [id], onDelete: Restrict)
  relationshipType String    @db.VarChar(100)
  effectiveFrom    DateTime
  effectiveTo      DateTime?
  createdAt        DateTime  @default(now())

  @@unique([parentCustomerId, childCustomerId, relationshipType, effectiveFrom])
  @@index([parentCustomerId, effectiveTo])
  @@index([childCustomerId, effectiveTo])
}

model CustomerOwnershipAssignment {
  id                 String            @id @default(cuid())
  customerId         String
  customer           Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  ownerId            String
  owner              User              @relation("CustomerOwnershipAssignee", fields: [ownerId], references: [id], onDelete: Restrict)
  organizationUnitId String?
  organizationUnit   OrganizationUnit? @relation(fields: [organizationUnitId], references: [id], onDelete: Restrict)
  validFrom          DateTime
  validTo            DateTime?
  assignedById       String
  assignedBy         User              @relation("CustomerOwnershipActor", fields: [assignedById], references: [id], onDelete: Restrict)
  reason             String?           @db.VarChar(1000)
  createdAt          DateTime          @default(now())

  @@index([customerId, validFrom, validTo])
  @@index([ownerId, validTo])
  @@index([organizationUnitId, validTo])
}

model CustomerMergeHistory {
  id               String   @id @default(cuid())
  sourceCustomerId String
  sourceCustomer   Customer @relation("CustomerMergeSource", fields: [sourceCustomerId], references: [id], onDelete: Restrict)
  targetCustomerId String
  targetCustomer   Customer @relation("CustomerMergeTarget", fields: [targetCustomerId], references: [id], onDelete: Restrict)
  mergedById       String
  mergedBy         User     @relation("CustomerMergeActor", fields: [mergedById], references: [id], onDelete: Restrict)
  reason           String   @db.VarChar(1000)
  sourceSnapshot   Json
  mergedAt         DateTime

  @@unique([sourceCustomerId])
  @@index([targetCustomerId, mergedAt])
}

model CustomerDuplicateCandidate {
  id                   String    @id @default(cuid())
  customerAId          String
  customerA            Customer  @relation("CustomerDuplicateA", fields: [customerAId], references: [id], onDelete: Restrict)
  customerBId          String
  customerB            Customer  @relation("CustomerDuplicateB", fields: [customerBId], references: [id], onDelete: Restrict)
  matchScore           Decimal   @db.Decimal(5, 4)
  matchSignals         Json
  detectedAt           DateTime  @default(now())
  resolvedAt           DateTime?
  resolutionReason     String?   @db.VarChar(1000)
  mergedIntoCustomerId String?
  mergedIntoCustomer   Customer? @relation("CustomerDuplicateMergeTarget", fields: [mergedIntoCustomerId], references: [id], onDelete: Restrict)

  @@unique([customerAId, customerBId])
  @@index([customerAId, resolvedAt])
  @@index([customerBId, resolvedAt])
}

model CustomerCommandReceipt {
  id             String   @id @default(cuid())
  actorId        String
  actor          User     @relation(fields: [actorId], references: [id], onDelete: Restrict)
  idempotencyKey String   @db.VarChar(191)
  command        String   @db.VarChar(100)
  targetId       String   @db.VarChar(191)
  targetVersion  Int?
  createdAt      DateTime @default(now())

  @@unique([actorId, idempotencyKey, command])
  @@index([createdAt])
}

model OrganizationUnit {
  id                           String                        @id @default(cuid())
  code                         String                        @unique @db.VarChar(100)
  name                         String                        @db.VarChar(255)
  parentId                     String?
  parent                       OrganizationUnit?             @relation("OrganizationHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children                     OrganizationUnit[]            @relation("OrganizationHierarchy")
  active                       Boolean                       @default(true)
  roleAssignments              UserRoleAssignment[]
  customers                    Customer[]
  opportunities                Opportunity[]
  customerOwnershipAssignments CustomerOwnershipAssignment[]
  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime                      @updatedAt
  leads                        Lead[]
  leadAssignmentRules          LeadAssignmentRule[]
  prospectBusinessUnits        Prospect[]                    @relation("ProspectBusinessUnit")
  prospectSalesTeams           Prospect[]                    @relation("ProspectSalesTeam")
  teamSalesTargets             SalesTarget[]                 @relation("SalesTargetTeam")
  departmentSalesTargets       SalesTarget[]                 @relation("SalesTargetDepartment")
  businessUnitSalesTargets     SalesTarget[]                 @relation("SalesTargetBusinessUnit")

  @@index([parentId, active])
}

model UserRoleAssignment {
  id                 String            @id @default(cuid())
  userId             String
  user               User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  roleCode           String            @db.VarChar(100)
  scopeCode          String            @db.VarChar(32)
  organizationUnitId String?
  organizationUnit   OrganizationUnit? @relation(fields: [organizationUnitId], references: [id], onDelete: Restrict)
  effectiveFrom      DateTime
  effectiveTo        DateTime?
  active             Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@unique([userId, roleCode, scopeCode, organizationUnitId, effectiveFrom])
  @@index([userId, active, effectiveFrom, effectiveTo])
  @@index([organizationUnitId, roleCode, active])
}

model RolePermissionGrant {
  id             String   @id @default(cuid())
  roleCode       String   @db.VarChar(100)
  permissionCode String   @db.VarChar(191)
  createdAt      DateTime @default(now())

  @@unique([roleCode, permissionCode])
  @@index([permissionCode, roleCode])
}

model Lead {
  id                     String                  @id @default(cuid())
  leadNumber             String?                 @unique @db.VarChar(32)
  leadType               LeadType                @default(CORPORATE)
  company                String
  taxId                  String?                 @db.VarChar(32)
  branchNumber           String?                 @db.VarChar(20)
  industry               String?                 @db.VarChar(191)
  website                String?                 @db.VarChar(500)
  contactName            String
  contactFirstName       String?                 @db.VarChar(191)
  contactLastName        String?                 @db.VarChar(191)
  jobTitle               String?                 @db.VarChar(191)
  department             String?                 @db.VarChar(191)
  contactEmail           String?
  contactPhone           String?
  source                 LeadSource
  campaignId             String?
  campaign               Campaign?               @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  status                 LeadStatus              @default(NEW)
  priority               LeadPriority            @default(MEDIUM)
  temperature            LeadTemperature         @default(COLD)
  score                  Int                     @default(0)
  scoreBreakdown         Json?
  recommendedProducts    String?                 @db.Text
  requirementSummary     String?                 @db.Text
  estimatedBudget        Decimal?                @db.Decimal(19, 4)
  expectedPurchaseAt     DateTime?
  numberOfSites          Int?
  serviceLocations       String?                 @db.Text
  qualificationData      Json?
  qualificationResult    String?                 @db.Text
  disqualificationReason String?                 @db.VarChar(1000)
  assignedAt             DateTime?
  firstContactDueAt      DateTime?
  lastContactedAt        DateTime?
  nextFollowUpAt         DateTime?
  convertedAt            DateTime?
  archivedAt             DateTime?
  notes                  String?                 @db.Text
  ownerId                String
  owner                  User                    @relation("LeadOwner", fields: [ownerId], references: [id])
  organizationUnitId     String?
  organizationUnit       OrganizationUnit?       @relation(fields: [organizationUnitId], references: [id], onDelete: SetNull)
  customerId             String?
  customer               Customer?               @relation(fields: [customerId], references: [id])
  contactId              String?
  contact                Contact?                @relation(fields: [contactId], references: [id], onDelete: SetNull)
  mergedIntoLeadId       String?
  mergedIntoLead         Lead?                   @relation("LeadMerge", fields: [mergedIntoLeadId], references: [id], onDelete: SetNull)
  mergedLeads            Lead[]                  @relation("LeadMerge")
  version                Int                     @default(1)
  commandReceipts        LeadCommandReceipt[]
  statusHistory          LeadStatusHistory[]
  assignmentHistory      LeadAssignmentHistory[]
  activities             Activity[]
  opportunity            Opportunity?            @relation("SourceLeadOpportunity")
  sourceProspect         Prospect?               @relation("ProspectConvertedLead")
  prospectContacts       ProspectContact[]
  salesDocuments         SalesDocument[]
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  @@index([ownerId, updatedAt, id])
  @@index([organizationUnitId, ownerId, status])
  @@index([status, updatedAt, id])
  @@index([temperature, score, updatedAt])
  @@index([nextFollowUpAt, status])
  @@index([firstContactDueAt, status])
  @@index([taxId])
  @@index([campaignId, status])
}

model Campaign {
  id        String     @id @default(cuid())
  code      String     @unique @db.VarChar(100)
  name      String     @db.VarChar(255)
  source    String     @db.VarChar(100)
  active    Boolean    @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  leads     Lead[]
  prospects Prospect[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model LeadNumberSequence {
  id        String   @id @db.VarChar(32)
  nextValue Int      @default(0)
  updatedAt DateTime @updatedAt
}

model LeadSavedView {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String   @db.VarChar(100)
  query     Json
  columns   Json?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId, isDefault])
}

model LeadAssignmentRule {
  id                 String                 @id @default(cuid())
  name               String                 @db.VarChar(191)
  priority           Int                    @default(100)
  active             Boolean                @default(true)
  strategy           LeadAssignmentStrategy
  criteria           Json
  targetOwnerId      String?
  targetOwner        User?                  @relation("LeadRuleTargetOwner", fields: [targetOwnerId], references: [id], onDelete: SetNull)
  organizationUnitId String?
  organizationUnit   OrganizationUnit?      @relation(fields: [organizationUnitId], references: [id], onDelete: SetNull)
  lastAssignedUserId String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([active, priority])
  @@index([organizationUnitId, active])
}

model LeadStatusHistory {
  id             String     @id @default(cuid())
  leadId         String
  lead           Lead       @relation(fields: [leadId], references: [id], onDelete: Restrict)
  fromStatus     LeadStatus
  toStatus       LeadStatus
  reason         String?    @db.VarChar(1000)
  actorId        String
  actor          User       @relation("LeadStatusActor", fields: [actorId], references: [id], onDelete: Restrict)
  correlationId  String     @db.VarChar(191)
  transitionedAt DateTime   @default(now())

  @@index([leadId, transitionedAt])
}

model LeadAssignmentHistory {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Restrict)
  fromOwnerId String?
  toOwnerId   String
  reason      String?  @db.VarChar(1000)
  actorId     String
  actor       User     @relation("LeadAssignmentActor", fields: [actorId], references: [id], onDelete: Restrict)
  assignedAt  DateTime @default(now())

  @@index([leadId, assignedAt])
}

model LeadCommandReceipt {
  id             String   @id @default(cuid())
  actorId        String
  actor          User     @relation(fields: [actorId], references: [id], onDelete: Restrict)
  idempotencyKey String   @db.VarChar(191)
  command        String   @db.VarChar(100)
  leadId         String
  lead           Lead     @relation(fields: [leadId], references: [id], onDelete: Restrict)
  customerId     String?
  contactId      String?
  opportunityId  String?
  resultLeadId   String?
  resultVersion  Int
  createdAt      DateTime @default(now())

  @@unique([actorId, idempotencyKey, command])
  @@index([leadId, createdAt])
  @@index([customerId, createdAt])
}

model Activity {
  id                                 String                    @id @default(cuid())
  version                            Int                       @default(1)
  subject                            String
  type                               ActivityType
  dueAt                              DateTime?
  notes                              String?                   @db.Text
  aiSummary                          String?                   @db.Text
  actionItems                        String?                   @db.Text
  ownerId                            String
  owner                              User                      @relation("ActivityOwner", fields: [ownerId], references: [id])
  statusCode                         String                    @default("OPEN") @db.VarChar(32)
  status                             ActivityStatusDefinition  @relation(fields: [statusCode], references: [code], onDelete: Restrict)
  completedAt                        DateTime?
  completionOutcome                  String?                   @db.Text
  customerId                         String?
  customer                           Customer?                 @relation(fields: [customerId], references: [id])
  opportunityId                      String?
  opportunity                        Opportunity?              @relation(fields: [opportunityId], references: [id])
  leadId                             String?
  lead                               Lead?                     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  prospectId                         String?
  prospect                           Prospect?                 @relation(fields: [prospectId], references: [id], onDelete: SetNull)
  description                        String?                   @db.Text
  activityAt                         DateTime?
  startsAt                           DateTime?
  endsAt                             DateTime?
  participants                       Json?
  outcome                            String?                   @db.Text
  customerFeedback                   String?                   @db.Text
  nextAction                         String?                   @db.Text
  nextFollowUpAt                     DateTime?
  createdAt                          DateTime                  @default(now())
  updatedAt                          DateTime                  @updatedAt
  deletedAt                          DateTime?
  deletedById                        String?
  meetingDraftConfirmation           MeetingDraftConfirmation? @relation("MeetingConfirmationActivity")
  meetingDraftNextActionConfirmation MeetingDraftConfirmation? @relation("MeetingConfirmationNextAction")

  @@index([leadId, createdAt])
  @@index([prospectId, createdAt])
  @@index([ownerId, deletedAt, createdAt])
  @@index([ownerId, statusCode, dueAt])
  @@index([statusCode, dueAt, deletedAt])
}

model ActivityStatusDefinition {
  code              String                     @id @db.VarChar(32)
  label             String                     @db.VarChar(100)
  sortOrder         Int
  reportingCategory String                     @db.VarChar(32)
  terminal          Boolean                    @default(false)
  active            Boolean                    @default(true)
  activities        Activity[]
  fromTransitions   ActivityStatusTransition[] @relation("ActivityTransitionFrom")
  toTransitions     ActivityStatusTransition[] @relation("ActivityTransitionTo")
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@index([active, sortOrder])
}

model ActivityStatusTransition {
  id                 String                   @id @default(cuid())
  fromStatusCode     String                   @db.VarChar(32)
  fromStatus         ActivityStatusDefinition @relation("ActivityTransitionFrom", fields: [fromStatusCode], references: [code], onDelete: Restrict)
  toStatusCode       String                   @db.VarChar(32)
